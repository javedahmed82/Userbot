# Copy these EXACTLY from your TeleBot Console dashboard (Config tab).
# IMPORTANT: API_BASE must be the stable host shown in the dashboard, e.g.
#   https://project--<project-id>-dev.lovable.app   (preview)
#   https://project--<project-id>.lovable.app       (after publish)
# Do NOT use the `id-preview--…lovable.app` URL from the editor — that one
# requires login and will redirect the bot to lovable.dev/auth-bridge.
USER_ID=your-user-uuid-here
API_TOKEN=your-api-token-here
API_BASE=https://project--your-project-id-dev.lovable.app
